{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImgGroup",
  "version": "1.0.1",
  "identifier": "com.xunxin.imggroup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5172",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ImgGroup - 图片分组浏览器",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": true,
		"maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
